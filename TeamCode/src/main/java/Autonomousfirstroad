package org.firstinspires.ftc.teamcode.drive;

import com.acmerobotics.roadrunner.geometry.Pose2d;
import com.qualcomm.robotcore.eventloop.opmode.Autonomous;
import com.qualcomm.robotcore.eventloop.opmode.LinearOpMode;

import org.firstinspires.ftc.teamcode.drive.SampleMecanumDrive;

@Autonomous(group = "drive")
public class Autonomousfirstroad extends LinearOpMode {

    private SampleMecanumDrive drive;

    @Override
    public void runOpMode() throws InterruptedException {

        drive = new SampleMecanumDrive(hardwareMap);

        // מצב התחלה
        Pose2d startPose = new Pose2d(12, -63, Math.toRadians(-90));
        drive.setPoseEstimate(startPose);
        double startY = startPose.getY();

        waitForStart();
        if (isStopRequested()) return;

        // MOVE 1 - 43 אינץ קדימה
        drive.followTrajectory(
                drive.trajectoryBuilder(drive.getPoseEstimate())
                        .forward(-43)
                        .build()
        );

        // 3 שניות "דמוי ירי"
        sleep(3000);

        // MOVE 2 - 10 אינץ נוספים קדימה
        drive.followTrajectory(
                drive.trajectoryBuilder(drive.getPoseEstimate())
                        .forward(-18)
                        .build()
        );

        // סיבוב 90 מעלות (לאיסוף)
        drive.turn(Math.toRadians(48));

        // MOVE 3 - 44 אינץ קדימה (על הכדורים)
        drive.followTrajectory(
                drive.trajectoryBuilder(drive.getPoseEstimate())
                        .forward(44)
                        .build()
        );


        // MOVE 4 - 40 אינץ אחורה
        drive.followTrajectory(
                drive.trajectoryBuilder(drive.getPoseEstimate())
                        .back(40)
                        .build()
        );

        // סיבוב 90 מעלות לכיוון ירי שני
        drive.turn(Math.toRadians(-50));

        double finalY = drive.getPoseEstimate().getY();
        double finalX = drive.getPoseEstimate().getX();
        double finalDeg = drive.getRawExternalHeading();

        telemetry.addData("Start Y", "%.1f", startY);
        telemetry.addData("Final X", "%.1f", finalX);
        telemetry.addData("Final Y", "%.1f", finalY);
        telemetry.addData("Final Deg", "%.1f", Math.toDegrees(finalDeg));
        telemetry.update();

        sleep(3000);
    }
}
